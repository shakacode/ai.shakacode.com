---
import Base from "../layouts/Base.astro";

const articles = [
  {
    href: "/openclaw-ubuntu-droplet-to-local-mac",
    title: "Migrating OpenClaw from an Ubuntu Droplet to a Local Mac",
    description:
      "A sanitized runbook for moving a live OpenClaw agent from Ubuntu to macOS while preserving long-lived state and fixing stale Linux path references.",
    category: "Migration Guide",
    date: "March 2026",
  },
  {
    href: "/codex-desktop-projects-worktrees-cleanup",
    title: "Codex Desktop App: Projects, Worktrees, Threads, Subagents, and Cleanup",
    description:
      "A practical guide to Codex desktop app workspace behavior: what Worktree mode means, when to create a new project, how subagents and custom agents work, and how auto-cleanup and retention settings work.",
    category: "Codex App Guide",
    date: "March 2026",
  },
  {
    href: "/executive-chef-model",
    title: "The Executive Chef Model",
    description:
      "How we govern AI-assisted development at ShakaCode. Every engineer is an executive chef: use whatever AI tools you want, and own what you ship.",
    category: "Governance Model",
    date: "February 2026",
  },
  {
    href: "/industry-survey",
    title: "How 10 Companies Are Governing AI-Assisted Development in 2026",
    description:
      "A survey of AI development policies across Shopify, Meta, GitLab, Anthropic, Google/DORA, Amazon, and others — with lessons for engineering leaders.",
    category: "Industry Research",
    date: "February 2026",
  },
];

const featuredArticle = articles[0] ?? null;
const otherArticles = articles.slice(1);
---

<Base
  title="Home"
  description="How ShakaCode approaches AI-assisted development — governance, research, and open-source tooling"
>
  <h1>AI Strategy at ShakaCode</h1>

  <p>
    We believe AI-assisted development is the most significant shift in software
    engineering since open source. This site documents how we're navigating it:
    our governance model, what we've learned from the industry, and the
    open-source tooling we've built along the way.
  </p>

  <p>
    Everything here is open source. If you disagree with something, think we're
    missing something, or have a better approach —
    <a href="https://github.com/shakacode/ai.shakacode.com/issues/new">open an issue</a>.
  </p>

  <section class="article-showcase">
    <h2>Featured Reading</h2>
    <p class="showcase-intro">
      Explore our latest writing on AI-assisted engineering, from practical
      Codex workflows to policy and governance patterns.
    </p>

    {
      featuredArticle && (
        <article class="featured-article">
          <p class="article-kicker">
            {featuredArticle.category} · {featuredArticle.date}
          </p>
          <h3>
            <a href={featuredArticle.href}>{featuredArticle.title}</a>
          </h3>
          <p>{featuredArticle.description}</p>
          <a class="read-more" href={featuredArticle.href}>Read featured article →</a>
        </article>
      )
    }

    <div class="article-grid">
      {
        otherArticles.map((article) => (
          <article class="article-card">
            <p class="article-kicker">
              {article.category} · {article.date}
            </p>
            <h3>
              <a href={article.href}>{article.title}</a>
            </h3>
            <p>{article.description}</p>
            <a class="read-more" href={article.href}>Read article →</a>
          </article>
        ))
      }
    </div>
  </section>

  <h2>Open-Source Tooling</h2>

  <p>
    Our AI development toolkit is open source at
    <a href="https://github.com/shakacode/claude-code-commands-skills-agents">
      github.com/shakacode/claude-code-commands-skills-agents</a
    >. It includes slash commands for self-review, security scanning (OWASP Top
    10), performance optimization, comprehensive PR review, a PR testing agent,
    and GitHub Actions for automated AI review on every pull request.
  </p>

  <h2>About ShakaCode</h2>

  <p>
    <a href="https://shakacode.com">ShakaCode</a> is a consultancy specializing
    in AI-augmented Ruby on Rails and React development. We're the company
    behind
    <a href="https://github.com/shakacode/react_on_rails">React on Rails</a>
    and the ShakaCode open-source ecosystem. Our products include
    <a href="https://www.shakacode.com/react-on-rails-pro/">React on Rails Pro</a
    >, HiChee, and ShakaFlow.
  </p>

  <p>
    If your team is navigating AI-assisted development and could use experienced
    partners who've already built the framework,
    <a href="https://shakacode.com">reach out</a>.
  </p>
</Base>
